# DIORA E-commerce Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# Required Variables
# =============================================================================

# API Configuration - Backend API base URL
NEXT_PUBLIC_API_URL=https://api.diora.com

# =============================================================================
# Optional Variables ( uncomment and fill as needed )
# =============================================================================

# Sentry Error Tracking (for production error monitoring)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# Google Analytics / GTM (for web analytics)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Meta Pixel (for Facebook/Instagram ad tracking)
# NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXX

# Stripe (for payment processing - server-side only)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (if using for backend/database)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
